# Copy this file to .env — NEVER commit .env to git

# ── Backend: Google Service Account ──────────────────────────────────────────
# Create at: console.cloud.google.com → APIs → Credentials → Service Account
# Enable: Google Sheets API + Google Drive API
# Share your Sheet with the service account email (as Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=YOUR_SHEET_ID
GOOGLE_DRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID

# ── Backend: Server config ────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Frontend: API endpoint ────────────────────────────────────────────────────
# Leave blank for local dev (Vite proxy handles /api → localhost:3001)
# Set to your deployed backend URL for production:
# VITE_API_URL=https://your-backend.vercel.app/api

# ── Frontend: OpenAI (AI resume parsing) ─────────────────────────────────────
VITE_OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── Frontend: Login (simple team password) ───────────────────────────────────
VITE_LOGIN_EMAIL=your@email.com
VITE_LOGIN_PASS=YourPassword
